<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- استبدال شعار أودو بشعار الحسن زكريا في نقطة البيع -->
    <t t-name="hz_debranding.PosNavbar" t-inherit="point_of_sale.Navbar" t-inherit-mode="extension">
        <xpath expr="//img[hasclass('pos-logo')]" position="attributes">
            <attribute name="src">/hz_debranding/static/src/img/logo.png</attribute>
            <attribute name="alt">الحسن زكريا</attribute>
        </xpath>
    </t>

</templates>
