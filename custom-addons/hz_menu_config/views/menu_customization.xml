<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ========================================== -->
    <!--  تعريب أسماء القوائم الرئيسية               -->
    <!--  وترتيبها حسب أولوية العمل                  -->
    <!-- ========================================== -->

    <!-- ===== المبيعات ===== -->
    <record id="sale.sale_menu_root" model="ir.ui.menu">
        <field name="name">المبيعات</field>
        <field name="sequence">10</field>
    </record>

    <!-- ===== المشتريات ===== -->
    <record id="purchase.menu_purchase_root" model="ir.ui.menu">
        <field name="name">المشتريات والاستيراد</field>
        <field name="sequence">20</field>
    </record>

    <!-- ===== المخزون ===== -->
    <record id="stock.menu_stock_root" model="ir.ui.menu">
        <field name="name">المخازن</field>
        <field name="sequence">30</field>
    </record>

    <!-- ===== المحاسبة ===== -->
    <record id="account.menu_finance" model="ir.ui.menu">
        <field name="name">المحاسبة والمالية</field>
        <field name="sequence">40</field>
    </record>

    <!-- ===== جهات الاتصال ===== -->
    <record id="contacts.menu_contacts" model="ir.ui.menu">
        <field name="name">العملاء والموردين</field>
        <field name="sequence">50</field>
    </record>

    <!-- ===== الموارد البشرية ===== -->
    <record id="hr.menu_hr_root" model="ir.ui.menu">
        <field name="name">الموارد البشرية</field>
        <field name="sequence">60</field>
    </record>

    <!-- ===== المراسلات / Discuss ===== -->
    <record id="mail.menu_root_discuss" model="ir.ui.menu">
        <field name="name">المراسلات</field>
        <field name="sequence">70</field>
    </record>

    <!-- ========================================== -->
    <!--  إخفاء التطبيقات غير المطلوبة               -->
    <!--  (مرئية فقط للمسؤول)                       -->
    <!-- ========================================== -->

    <!-- إخفاء قائمة Apps/التطبيقات (تم في hz_debranding أيضاً) -->
    <record id="base.menu_management" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- إخفاء الإعدادات التقنية -->
    <record id="base.menu_custom" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

</odoo>
