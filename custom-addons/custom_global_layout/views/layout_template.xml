<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!--  القالب الخارجي الموحّد — الهيدر والفوتر لجميع المستندات      -->
        <!-- ============================================================ -->

        <template id="hz_external_layout" inherit_id="web.external_layout_standard">

            <!-- ===== استبدال الهيدر بالكامل ===== -->
            <xpath expr="//div[contains(@t-attf-class, 'header')]" position="replace">
                <div t-attf-class="header o_company_#{company.id}_layout" style="font-family: 'Cairo', 'Arial', sans-serif;">
                    <div style="border-bottom: 3px solid #0D47A1; padding-bottom: 10px; margin-bottom: 8px;">
                        <div class="row align-items-center" dir="ltr">
                            <!-- معلومات إنجليزية — يسار -->
                            <div class="col-4 text-start" dir="ltr" style="text-align: left; color: #0D47A1;">
                                <strong style="font-size: 11px;">Al-Hassan Zakaria Medical Supplies</strong>
                                <t t-if="company._name == 'res.company'">
                                    <div style="font-size: 9px; color: #555; margin-top: 2px;">
                                        Sana'a, Yemen
                                    </div>
                                    <div style="font-size: 9px; color: #555;">
                                        Medical License No. ...
                                    </div>
                                </t>
                            </div>
                            <!-- الشعار — وسط -->
                            <div class="col-4 text-center">
                                <img t-if="company.logo" t-att-src="image_data_uri(company.logo)"
                                     style="max-height: 65px; max-width: 150px;" alt="شعار الشركة"/>
                            </div>
                            <!-- معلومات عربية — يمين -->
                            <div class="col-4 text-end" style="color: #0D47A1;">
                                <strong style="font-size: 11px;">
                                    <t t-esc="company.name"/>
                                </strong>
                                <t t-if="company._name == 'res.company'">
                                    <div style="font-size: 9px; color: #555; margin-top: 2px;">
                                        <t t-if="company.street"><t t-esc="company.street"/></t>
                                        <t t-if="company.city"> - <t t-esc="company.city"/></t>
                                    </div>
                                    <div t-if="company.vat" style="font-size: 9px; color: #555;">
                                        الرقم الضريبي: <t t-esc="company.vat"/>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>

            <!-- ===== تطبيق RTL + خط على المحتوى ===== -->
            <xpath expr="//div[contains(@t-attf-class, 'article')]" position="attributes">
                <attribute name="style">font-family: 'Cairo', 'Arial', sans-serif; direction: rtl; text-align: right;</attribute>
            </xpath>

            <!-- ===== استبدال الفوتر بالكامل ===== -->
            <xpath expr="//div[contains(@t-attf-class, 'footer')]" position="replace">
                <div t-attf-class="footer o_standard_footer o_company_#{company.id}_layout" style="font-family: 'Cairo', 'Arial', sans-serif;">
                    <!-- شعار صغير في المنتصف -->
                    <div class="text-center" style="margin-bottom: 6px;">
                        <img t-if="company.logo" t-att-src="image_data_uri(company.logo)"
                             style="max-height: 35px; opacity: 0.5;" alt=""/>
                    </div>
                    <div style="border-top: 2px solid #0D47A1; padding-top: 8px;">
                        <div class="text-center" style="margin-bottom: 6px;">
                            <strong style="color: #0D47A1; font-size: 9px;">العنوان والتواصل</strong>
                        </div>
                        <div class="row" dir="ltr" style="font-size: 8px; color: #555;">
                            <div class="col-4 text-center">
                                <t t-if="company._name == 'res.company'">
                                    <span style="color: #0D47A1;">&#x1F4CD;</span>
                                    <t t-if="company.street"><t t-esc="company.street"/></t>
                                    <t t-if="company.city"> - <t t-esc="company.city"/></t>
                                </t>
                            </div>
                            <div class="col-4 text-center">
                                <span style="color: #0D47A1;">&#x1F4DE;</span>
                                <t t-if="company._name == 'res.company' and company.mobile">
                                    جوال: <t t-esc="company.mobile"/>
                                </t>
                                <t t-if="company.phone">
                                    | هاتف: <t t-esc="company.phone"/>
                                </t>
                            </div>
                            <div class="col-4 text-center">
                                <span style="color: #0D47A1;">&#x2709;</span>
                                <t t-if="company.email">
                                    <t t-esc="company.email"/>
                                </t>
                            </div>
                        </div>
                        <div t-if="report_type == 'pdf'" class="text-center" style="margin-top: 4px; font-size: 7px; color: #999;">
                            صفحة <span class="page"/> من <span class="topage"/>
                        </div>
                    </div>
                </div>
            </xpath>

        </template>

    </data>
</odoo>