<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  قالب أمر الشراء — الحسن زكريا                                -->
    <!--  الأصلي: purchase.report_purchaseorder_document               -->
    <!--  أسماء الأعمدة: th_description, th_date_req, th_quantity,     -->
    <!--                  th_price_unit, th_discount, th_taxes,        -->
    <!--                  th_subtotal                                  -->
    <!-- ============================================================ -->

    <template id="hz_purchase_order_document"
              inherit_id="purchase.report_purchaseorder_document"
              name="HZ Unified Purchase Order">

        <!-- ===== تعريب عناوين جدول البنود ===== -->
        <xpath expr="//th[@name='th_description']" position="replace">
            <th name="th_description"><strong>وصف المنتج</strong></th>
        </xpath>
        <xpath expr="//th[@name='th_date_req']" position="replace">
            <th name="th_date_req" class="text-center"><strong>تاريخ التسليم</strong></th>
        </xpath>
        <xpath expr="//th[@name='th_quantity']" position="replace">
            <th name="th_quantity" class="text-end"><strong>الكمية</strong></th>
        </xpath>
        <xpath expr="//th[@name='th_price_unit']" position="replace">
            <th name="th_price_unit" class="text-end"><strong>سعر الوحدة</strong></th>
        </xpath>
        <xpath expr="//th[@name='th_discount']" position="replace">
            <th name="th_discount" class="text-end"><strong>خصم</strong></th>
        </xpath>
        <xpath expr="//th[@name='th_taxes']" position="replace">
            <th name="th_taxes" class="text-end"><strong>الضرائب</strong></th>
        </xpath>
        <xpath expr="//th[@name='th_subtotal']" position="replace">
            <th name="th_subtotal" class="text-end">
                <strong>الإجمالي</strong>
            </th>
        </xpath>

        <!-- ===== إضافة كلاس الجدول الموحّد ===== -->
        <xpath expr="//thead/.." position="attributes">
            <attribute name="class">table table-sm o_main_table table-borderless mt-4 hz-table</attribute>
        </xpath>

        <!-- ===== قسم التوقيعات ===== -->
        <xpath expr="//p[@t-field='o.notes']" position="after">
            <div class="hz-signature-section">
                <div class="row">
                    <div class="col-4 text-center">
                        <div class="hz-signature-line">
                            <span>توقيع المورّد</span>
                        </div>
                    </div>
                    <div class="col-4 text-center">
                        <div class="hz-signature-line">
                            <span>مدير المشتريات</span>
                        </div>
                    </div>
                    <div class="col-4 text-center">
                        <div class="hz-signature-line">
                            <span>الاعتماد</span>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>

    </template>

</odoo>
