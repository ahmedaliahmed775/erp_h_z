<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  قالب الفاتورة الموحّد — الحسن زكريا                          -->
    <!-- ============================================================ -->

    <template id="hz_invoice_document"
              inherit_id="account.report_invoice_document"
              name="HZ Unified Invoice">

        <!-- ===== تعريب عناوين جدول البنود ===== -->
        <xpath expr="//th[@name='th_description']" position="replace">
            <th name="th_description" class="text-start"><span>تفاصيل الصنف</span></th>
        </xpath>
        <xpath expr="//th[@name='th_quantity']" position="replace">
            <th name="th_quantity" class="text-end"><span>الكمية</span></th>
        </xpath>
        <xpath expr="//th[@name='th_priceunit']" position="replace">
            <th name="th_priceunit" class="text-end"><span>سعر الوحدة</span></th>
        </xpath>
        <xpath expr="//th[@name='th_taxes']" position="replace">
            <th name="th_taxes" class="text-end"><span>الضرائب</span></th>
        </xpath>
        <xpath expr="//th[@name='th_subtotal']" position="replace">
            <th name="th_subtotal" class="text-end"><span>الإجمالي</span></th>
        </xpath>

        <!-- ===== إضافة كلاس الجدول الموحّد ===== -->
        <xpath expr="//table[@name='invoice_line_table']" position="attributes">
            <attribute name="class">table table-sm o_main_table hz-table</attribute>
        </xpath>

        <!-- ===== قسم التوقيعات ===== -->
        <xpath expr="//div[@name='comment']" position="after">
            <div class="hz-signature-section">
                <div class="row">
                    <div class="col-6 text-center">
                        <div class="hz-signature-line">
                            <span>توقيع المستلم / الختم</span>
                        </div>
                    </div>
                    <div class="col-6 text-center">
                        <div class="hz-signature-line">
                            <span>توقيع المسؤول / الختم</span>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>

    </template>

</odoo>
