<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  أعمار الأرصدة (Aged Partner Balance)                        -->
    <!--  الأصلي: base_accounting_kit.report_agedpartnerbalance       -->
    <!-- ============================================================ -->

    <template id="hz_report_aged_partner"
              inherit_id="base_accounting_kit.report_agedpartnerbalance"
              name="HZ Aged Partner Balance">

        <xpath expr="//table[hasclass('table')]" position="attributes">
