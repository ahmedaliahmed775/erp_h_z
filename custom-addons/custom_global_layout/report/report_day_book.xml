<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  دفتر اليومية PDF (Day Book)                                 -->
    <!--  الأصلي: base_accounting_kit.day_book_report_template        -->
    <!-- ============================================================ -->

    <template id="hz_report_day_book"
              inherit_id="base_accounting_kit.day_book_report_template"
              name="HZ Day Book">

        <xpath expr="//table[hasclass('table')]" position="attributes">
            <attribute name="class">table table-sm table-condensed hz-table</attribute>
        </xpath>

    </template>

</odoo>
